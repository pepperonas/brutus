<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Subtle circular halo behind the monogram (stays inside safe zone) -->
    <path
        android:strokeColor="#22E53935"
        android:strokeWidth="0.8"
        android:fillColor="#00000000"
        android:pathData="M54,54 m-30,0 a30,30 0,1 1,60 0 a30,30 0,1 1,-60 0" />

    <!-- Monogram 'B' with even-odd fill. Top bump is slightly smaller than the
         bottom — mirrors classic serif proportions for a premium feel. -->
    <path
        android:fillType="evenOdd"
        android:pathData="M 38,32 L 58,32 C 66,32 72,36 72,44 C 72,50 68,52 64,54 C 70,56 74,60 74,66 C 74,72 68,76 60,76 L 38,76 Z M 46,38 L 56,38 C 60,38 64,40 64,44 C 64,48 60,50 56,50 L 46,50 Z M 46,58 L 58,58 C 62,58 66,60 66,66 C 66,70 62,72 58,72 L 46,72 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="38" android:startY="32"
                android:endX="74" android:endY="76"
                android:startColor="#FF5A54"
                android:endColor="#B71C1C" />
        </aapt:attr>
    </path>

    <!-- Thin highlight stroke along left spine for crisp edge -->
    <path
        android:fillColor="#44FFFFFF"
        android:pathData="M 38,32 L 40,32 L 40,76 L 38,76 Z" />
</vector>
